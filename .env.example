# Slack Incoming Webhook URL
# Get from: api.slack.com > Your Apps > Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE/WITH/YOUR_WEBHOOK
# Google Service Account JSON (minified, single line)
# Get from: Google Cloud Console > IAM & Admin > Service Accounts > Keys
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
